    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": ["electron", "accounting", "kaikei", "government"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
